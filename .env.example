# DeepSeek API 配置（用于AI内容生成）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 天气 API 配置
# 支持的提供商: openweathermap, juhe
WEATHER_PROVIDER=openweathermap

# OpenWeatherMap API 密钥（如果使用openweathermap）
WEATHER_API_KEY=your_openweathermap_api_key_here

# 聚合数据(juhe) 天气 API 密钥（如果使用juhe）
JUHE_WEATHER_API_KEY=your_juhe_weather_api_key_here

# 新闻 API 配置  
# 支持的提供商: newsapi, juhe
NEWS_PROVIDER=newsapi

# NewsAPI 密钥（如果使用newsapi）
NEWS_API_KEY=your_newsapi_key_here

# 聚合数据(juhe) 新闻 API 密钥（如果使用juhe）
JUHE_NEWS_API_KEY=your_juhe_news_api_key_here